{
  "manifest_version": 3,
  "name": "Aniwatch",
  "version": "1.0.0",
  "action": {
    "default_popup": "index.html"
  }, 
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["scripts/content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["scripts/page-bridge.js"],
      "matches": ["<all_urls>"]
    }
  ]
}